package calculadora;

import java.math.BigDecimal;
import java.math.RoundingMode;
import java.util.Scanner;

public class Calculadora {
    public static void main(String[] args) {

        Scanner teclado = new Scanner(System.in);

        Divisao divisao = new Divisao();
        Estatistica estatistica = new Estatistica();
        Financeira financeira = new Financeira();

        int opcao;

        while(true) {
            System.out.println("=== MINI TERMINAL ===");
            System.out.println("1 - Divisão");
            System.out.println("2 - Média de idades");
            System.out.println("3 - Divisão financeira" + "");
            System.out.println("0 - Sair");
            System.out.print("Ecolha: ");
            opcao = teclado.nextInt();
            if(opcao == 0) {
            	break;
            } else {
            switch (opcao) {

             
                case 1:
                    System.out.print("Digite o primeiro número: ");
                    double valor1 = teclado.nextDouble();

                    boolean valido = false;

                    while (!valido) {
                        try {
                            System.out.print("Digite o segundo número: ");
                            double valor2 = teclado.nextDouble();

                            double resultado = divisao.calculaDivisao(valor1, valor2);
                            System.out.println("Resultado: " + resultado);

                            valido = true;

                        } catch (IllegalArgumentException e) {
                            System.out.println(e.getMessage());
                            System.out.println("Tente novamente.");
                        }
                    }
                    break;

                
                case 2:
                    System.out.print("Quantas idades deseja informar? ");
                    int tamanho = teclado.nextInt();

                    int[] idades = new int[tamanho];

                    for (int i = 0; i < tamanho; i++) {
                        System.out.print("Digite a idade: ");
                        idades[i] = teclado.nextInt();
                    }

                    try {
                        double media = estatistica.calcularMedia(idades);
                        System.out.println("Média: " + media);

                    } catch (ArithmeticException e) {
                        System.out.println(e.getMessage());
                    }
                    break;

      
                case 3:
                    System.out.print("Digite o primeiro valor: ");
                    BigDecimal num1 = teclado.nextBigDecimal();

                    System.out.print("Digite o segundo valor: ");
                    BigDecimal num2 = teclado.nextBigDecimal();

                    try {
                        BigDecimal resultado = financeira.dividir(num1, num2);
                        System.out.println("Resultado: " + resultado);

                    } catch (ArithmeticException e) {
                        System.out.println("Erro: divisão com dízima periódica!");

                        BigDecimal corrigido =
                                num1.divide(num2, 2, RoundingMode.HALF_UP);

                        System.out.println("Resultado corrigido: " + corrigido);
                    }
                    break;

                case 0:
                    System.out.println("Encerrando...");
                    break;

                default:
                    System.out.println("Opção inválida!");
            }

        } //while (opcao != 0); // lembrar de usar o dowhile (estudar);

         
    }
}
  
}
