package calculadora;

public class Estatistica {

    public double calcularMedia(int[] idades) {

        int soma = 0;

        for (int i = 0; i < idades.length; i++) {
            soma += idades[i];
        }

  
        if (idades.length == 0) {
            throw new ArithmeticException("Conjunto de dados vazio: impossível calcular a média");
        }

        return soma / idades.length;
    }
}
